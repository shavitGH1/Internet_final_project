{
  "name": "back_a",
  "version": "1.0.0",
  "description": "Recipe sharing application backend",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsc && node --env-file=.env.dev ./dist/Recipe_internet_project/src/server.js",
    "dev": "dotenv -e ./Recipe_internet_project/.env.dev nodemon --exec ts-node ./Recipe_internet_project/src/server.ts",
    "lint": "eslint . --ext .ts",
    "test": "tsc && jest --runInBand --detectOpenHandles --forceExit",
    "testcomment": "tsc && jest --runInBand --detectOpenHandles --forceExit Recipe_internet_project/src/tests/comments.test.ts",
    "testrecipe": "tsc && jest --runInBand --detectOpenHandles --forceExit Recipe_internet_project/src/tests/recipes.test.ts",
    "testauth": "tsc && jest --runInBand --detectOpenHandles --forceExit Recipe_internet_project/src/tests/auth.test.ts",
    "frontend": "cd Recipe_internet_project/tastebuds-frontend && npm start",
    "backend": "npm run dev",
    "start:both": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install:all": "npm install && cd Recipe_internet_project/tastebuds-frontend && npm install"
  },
  "author": "Tastebuds Team - Gal & Shavit",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.19.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
